{
    "name": "aiya-cms-pro",
    "version": "1.0.0",
    "description": "AIYA-CMS Theme for WordPress",
    "main": "index.js",
    "keywords": [],
    "author": "Yeraph",
    "license": "ISC",
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.1",
        "@tailwindcss/typography": "^0.5.2",
        "@wordpress/scripts": "^30.1.0",
        "dir-archiver": "^2.1.0",
        "gulp": "^5.0.0",
        "prettier": "^2.7.1",
        "prettier-plugin-tailwindcss": "^0.1.13",
        "rtlcss": "^4.3.0",
        "tailwindcss": "^3.4.17"
    },
    "scripts": {
        "dev": "npx tailwindcss -i tailwind.css -o assets/css/main.style.css --watch",
        "build": "npx tailwindcss -i tailwind.css -o assets/css/main.style.css --minify",
        "lint:css": "wp-scripts lint-style 'assets/css/**/*.css'",
        "lint:js": "wp-scripts lint-js 'assets/js/*.js'",
        "archive": "dir-archiver --src ./ --dest ../aiya-cms-releases.zip --exclude .DS_Store .git .gitattributes .github .gitignore README.md composer.json composer.lock node_modules build vendor package.json package-lock.json tailwind.css tailwind.config.js"
    }
}
