{
    "name": "aiya/wordpress-cms-theme",
    "type": "wordpress-theme",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1",
        "wp-cli/i18n-command": "^2.6",
        "wp-cli/wp-cli-bundle": "^2.12"
    },
    "repositories": {
        "packagist": {
            "type": "composer",
            "url": "https://mirrors.cloud.tencent.com/composer/"
        }
    },
    "scripts": {
        "php:lint": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor --exclude node_modules --exclude build --exclude dist .",
        "php:cs": "@php ./vendor/bin/phpcs --standard=.phpcs.xml.dist",
        "php:cbf": "@php ./vendor/bin/phpcbf --standard=.phpcs.xml.dist",
        "php:stan": "@php ./vendor/bin/phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "i18n:pot": "@php ./vendor/bin/wp i18n make-pot . languages/aiya-cms.pot --exclude=node_modules,build,dist,vendor,.trae",
        "i18n:json": "@php ./vendor/bin/wp i18n make-json languages --no-purge"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
